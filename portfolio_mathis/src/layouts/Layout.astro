---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const basePath = import.meta.env.BASE_URL;
const faviconUrl = `${basePath}favicon.ico`;
const faviconSvgUrl = `${basePath}favicon.svg`;
const appleTouchIconUrl = `${basePath}apple-touch-icon.png`;

const siteName = "Mathis DETROUSSAT";
const defaultTitle = "Mathis Detroussat — Chargé de projet événementiel";
const defaultDescription =
  "Portfolio de Mathis Detroussat, chargé de projet événementiel. Découvrez mon parcours, mes projets, mes réalisations et mes expériences dans l'événementiel.";

const {
  title,
  description = defaultDescription,
  ogImage = "og-image.jpg",
  noindex = false,
} = Astro.props;

// Titre final : "Page | Mathis DETROUSSAT" (sauf si le titre contient déjà le nom).
const pageTitle = title
  ? title.includes(siteName) || title.includes("Mathis")
    ? title
    : `${title} | ${siteName}`
  : defaultTitle;

// URL canonique et OG calculées à partir de la page courante.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mathis Detroussat" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />

    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/x-icon" href={faviconUrl} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={faviconSvgUrl} />
    <link rel="apple-touch-icon" href={appleTouchIconUrl} />

    <meta property="og:locale" content="fr_FR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Mathis DETROUSSAT — Portfolio" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Aperçu du portfolio de Mathis DETROUSSAT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Mathis Detroussat",
      url: Astro.site?.href,
      image: ogImageURL.href,
      jobTitle: "Chargé de projet événementiel",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Clermont-Ferrand",
        addressCountry: "FR"
      },
      sameAs: [
        "https://www.linkedin.com/in/mathis-detroussat-89b0a4271/"
      ]
    })} />
  </head>

  <body class="m-0 min-h-screen w-full bg-[#f8f6f2]">
    <Navbar />

    <main class="pt-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>