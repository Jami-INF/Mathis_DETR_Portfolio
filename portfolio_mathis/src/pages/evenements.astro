---
import Layout from '../layouts/Layout.astro';
import ProjetsSection from '../components/section/projet/ProjetsSection.astro';
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';

// Toutes les images optimisables du projet, résolues par leur chemin.
// Mathis n'écrit qu'un nom de fichier dans le YAML, le code fait le lien.
const images = import.meta.glob<ImageMetadata>(
  '/src/assets/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true, import: 'default' }
);

// Contenu éditable : src/content/evenements.yaml
const entries = await getCollection('evenements');
entries.sort((a, b) => a.data.ordre - b.data.ordre);
const evenements = entries.map(({ data }) => ({
  title: data.titre,
  title2: data.titre2,
  role: data.role,
  description: data.description,
  missions: data.missions,
  results: data.resultats,
  image: data.image ? images[`/src/assets/${data.image}`] : undefined,
  imageAlt: data.alt,
  galerie: data.galerie || undefined,
}));
---

<Layout
  title="Événements"
  description="Les événements, concerts et salons auxquels Mathis Detroussat a participé : organisation, régie technique et coordination."
>
  <main class="pt-20">
    <h1 class="sr-only">Événements de Mathis Detroussat</h1>
    <ProjetsSection
      projets={evenements}
      title="Mes événements"
      sectionId="evenements"
    />
  </main>
</Layout>
