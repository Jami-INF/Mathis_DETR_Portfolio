---
// src/pages/competences.astro
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

import CompetenceSection from "../components/section/competence/CompetenceSection.astro";
import SkillsSection from "../components/section/competence/skills/SkillsSection.astro";
import ToolsSection from "../components/section/competence/ToolsSection.astro";

// Contenu éditable : src/content/competences.yaml (4 sections).
const hardData = (await getEntry('competences', 'hard-skills'))?.data;
const softData = (await getEntry('competences', 'soft-skills'))?.data;
const outilsData = (await getEntry('competences', 'outils'))?.data;
const detailsData = (await getEntry('competences', 'details'))?.data;

// Les composants attendent `title` ; le YAML utilise `titre` (français) → on mappe.
const mapSkills = (skills = []) =>
  skills.map((s) => ({ title: s.titre, icon: s.icon, niveau: s.niveau, items: s.items }));

const hardSkills = mapSkills(hardData?.skills);
const softSkills = mapSkills(softData?.skills);
const outils = outilsData?.groupes ?? [];
const blocs = (detailsData?.blocs ?? []).map((b) => ({
  title: b.titre,
  sousTitre: b.sousTitre,
  moyenne: b.moyenne,
  competences: b.competences,
}));
---

<Layout
  title="Compétences"
  description="Compétences de Mathis Detroussat en gestion de projet événementiel : conception, logistique, régie, communication et coordination."
>
  <main class="relative overflow-hidden pt-20">
    <h1 class="sr-only">Compétences de Mathis Detroussat en événementiel</h1>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-[0.06]"
      style="background-image:
        linear-gradient(to right, rgba(65, 56, 48, 0.5) 2px, transparent 2px),
        linear-gradient(to bottom, rgba(65, 56, 48, 0.5) 2px, transparent 2px);
        background-size: 46px 46px;"
    ></div>
    <div class="relative z-10">
      <SkillsSection title="Hard skills" skills={hardSkills} variant="rose" />
      <SkillsSection title="Soft skills" skills={softSkills} variant="brun" />
      <ToolsSection title="Logiciels & outils" groupes={outils} />
      <CompetenceSection blocs={blocs} />
    </div>
  </main>
</Layout>
