---
import Layout from '../layouts/Layout.astro';
import ProjetsSection from '../components/section/projet/ProjetsSection.astro';
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';

// Toutes les images optimisables du projet, résolues par leur chemin
// (ex: "projets/hall32.jpg" -> /src/assets/projets/hall32.jpg).
// Mathis n'écrit qu'un nom de fichier dans le YAML, le code fait le lien.
const images = import.meta.glob<ImageMetadata>(
  '/src/assets/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true, import: 'default' }
);

// Contenu éditable : src/content/projets.yaml
const entries = await getCollection('projets');
entries.sort((a, b) => a.data.ordre - b.data.ordre);
const projets = entries.map(({ data }) => ({
  title: data.titre,
  title2: data.titre2,
  role: data.role,
  description: data.description,
  missions: data.missions,
  results: data.resultats,
  image: data.image ? images[`/src/assets/${data.image}`] : undefined,
  imageAlt: data.alt,
  galerie: data.galerie || undefined,
}));
---

<Layout
  title="Projets"
  description="Projets et structures événementielles de Mathis Detroussat : Molo Molo Records, Master Juice Production et missions au Hall 32."
>
  <main class="pt-20">
    <h1 class="sr-only">Projets événementiels de Mathis Detroussat</h1>
    <ProjetsSection projets={projets} title="Mes projets" sectionId="projets" />
  </main>
</Layout>
