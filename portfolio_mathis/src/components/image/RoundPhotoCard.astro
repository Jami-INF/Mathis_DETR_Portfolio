---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
}

const {
  src,
  alt = "Photo",
} = Astro.props;
---

<div class="relative w-[220px] sm:w-[380px] lg:w-[560px]">
  <div class="absolute inset-x-[8%] top-[-50%] -bottom-[50%] -z-10 rounded-[36px] bg-[#edd1f1]"></div>

  <div class="aspect-square overflow-hidden rounded-full bg-[#edd1f1] p-2 shadow-lg">
    {
      typeof src === "string" ? (
        <img
          src={src}
          alt={alt}
          class="block h-full w-full rounded-full object-cover"
          loading="lazy"
        />
      ) : (
        <Image
          src={src}
          alt={alt}
          class="block h-full w-full rounded-full object-cover"
        />
      )
    }
  </div>
</div>