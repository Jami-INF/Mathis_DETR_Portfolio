---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
}

const {
  src,
  alt = "Photo",
} = Astro.props;
---

<div class="absolute right-[6%] top-[16%] z-10 w-[35vw] min-w-[260px] max-w-[420px] rotate-[-7deg]">
  <div class="bg-white p-2 rounded-[24px] shadow-lg">
    {
      typeof src === "string" ? (
        <img
          src={src}
          alt={alt}
          class="block aspect-[4/5] w-full rounded-[18px] object-cover"
          loading="lazy"
        />
      ) : (
        <Image
          src={src}
          alt={alt}
          class="block aspect-[4/5] w-full rounded-[18px] object-cover"
        />
      )
    }
  </div>
</div>