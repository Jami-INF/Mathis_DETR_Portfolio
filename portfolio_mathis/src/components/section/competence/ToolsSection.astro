---
// src/components/section/competence/ToolsSection.astro
import BigTitle from "./../../text/BigTitle.astro";
import FloatingAsset from "./../../decor/DessinVolant.astro";
import EtoileMarron from "./../../../assets/element/etoileMarron.png";

const { title = "Logiciels & outils", groupes = [] } = Astro.props;
const slug = title.toLowerCase().replace(/\s+/g, "-");
---

<section aria-labelledby={`${slug}-title`} class="relative mx-auto max-w-7xl px-4 mb-16 sm:px-6 sm:mb-28 lg:px-8">
  <FloatingAsset
    src={EtoileMarron}
    alt=""
    class="right-2 -top-4 z-0 w-[52px] rotate-[12deg] opacity-80 sm:right-6 sm:w-[72px] lg:w-[88px]"
    imgClass="h-auto w-full"
  />
  <BigTitle line1={title} line2='' sizeClass="text-[2.5rem] sm:text-[3.5rem] lg:text-[4.5rem]"/>

  <div class="relative z-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {groupes.map((g) => (
      <article class="rounded-3xl bg-white/90 p-6 ring-1 ring-[#f1ddef] shadow-lg shadow-[#e7a7f4]/20">
        <h3 class="mb-4 font-display text-lg font-extrabold uppercase tracking-wide text-[#b05ec0]">
          {g.categorie}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {g.items.map((item) => (
            <li class="rounded-full bg-[#fbeefb] px-3 py-1.5 text-sm font-semibold text-[#6f5647] ring-1 ring-[#f0d9ee]">
              {item}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
