---
// src/components/section/competence/RadialGauge.astro
// Jauge circulaire réutilisable, dans la DA "pop" du site.
const {
  value = 0,
  max = 100,
  size = 116,
  stroke = 12,
  from = "#e29bdb",
  to = "#c267bd",
  track = "#f4e3f2",
  label = "",
  unit = "",
  textColor = "#b05ec0",
  labelClass = "text-3xl",
} = Astro.props;

const pct = Math.min(100, Math.max(0, (value / max) * 100));
const r = (size - stroke) / 2;
const circ = 2 * Math.PI * r;
const offset = circ * (1 - pct / 100);
const gid = "rg-" + Math.random().toString(36).slice(2, 9);
---

<div class="relative shrink-0" style={`width:${size}px;height:${size}px`}>
  <svg viewBox={`0 0 ${size} ${size}`} class="h-full w-full -rotate-90">
    <defs>
      <linearGradient id={gid} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color={from} />
        <stop offset="100%" stop-color={to} />
      </linearGradient>
    </defs>
    <circle cx={size / 2} cy={size / 2} r={r} fill="none" stroke={track} stroke-width={stroke} />
    <circle
      cx={size / 2}
      cy={size / 2}
      r={r}
      fill="none"
      stroke={`url(#${gid})`}
      stroke-width={stroke}
      stroke-linecap="round"
      stroke-dasharray={circ}
      stroke-dashoffset={offset}
      style="transition: stroke-dashoffset 1s ease"
    />
  </svg>
  <div class="absolute inset-0 flex flex-col items-center justify-center leading-none" style={`color:${textColor}`}>
    <span class={`font-display font-black ${labelClass}`}>{label}</span>
    {unit && <span class="text-xs font-bold opacity-70">{unit}</span>}
  </div>
</div>
