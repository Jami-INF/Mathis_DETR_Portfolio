---
// src/components/section/skills/SkillCard.astro
const { skill } = Astro.props;
const pct = Math.min(100, Math.max(0, skill.niveau ?? 0));
---

<div>
  <div class="mb-6 flex h-12 overflow-hidden rounded-full bg-[#5c4435]">
    <div
      class="flex h-full items-center justify-center bg-[#e8d5f4]"
      style={`width:${pct}%`}
    >
      <span class="text-sm font-bold text-[#5c4435]">{pct}%</span>
    </div>
  </div>

  <h3 class="mb-4 text-center text-2xl font-bold text-[#4a3528] sm:text-3xl">
    {skill.title}
  </h3>

  <ul class="mx-auto max-w-xs space-y-1.5 text-[#5c4435]">
    {skill.items.map((item) => (
      <li class="flex items-start justify-center gap-2 text-center">
        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#5c4435]"></span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>