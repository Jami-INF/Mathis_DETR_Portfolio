---
// src/components/section/competence/skills/SkillCard.astro
const { skill, variant = "rose" } = Astro.props;

// Échelle qualitative (pas de pourcentage : niveau assumé, lisible).
const tiers = ["Débutant", "Intermédiaire", "Avancé", "Expert"];
const tierIndex = Math.max(0, tiers.indexOf(skill.niveau));
const filled = tierIndex + 1;

const themes = {
  rose: {
    card: "bg-[#fdf0ff]/95 ring-[#edd1f1] shadow-[#e7a7f4]/30",
    title: "text-[#b05ec0]",
    dot: "bg-[#e7a7f4]",
    text: "text-[#6f5647]",
    pill: "bg-[#e7a7f4] text-white",
    iconWrap: "bg-[#e7a7f4] text-white",
    seg: "bg-[#c267bd]",
    segOff: "bg-[#f0d9ee]",
    watermark: "text-[#e7a7f4]/15",
  },
  brun: {
    card: "bg-[#faf6f0]/95 ring-[#e6d6c8] shadow-[#c4a07d]/25",
    title: "text-[#7a5b46]",
    dot: "bg-[#b08a6b]",
    text: "text-[#5c4435]",
    pill: "bg-[#7a5b46] text-white",
    iconWrap: "bg-[#7a5b46] text-white",
    seg: "bg-[#7a5b46]",
    segOff: "bg-[#e6dccf]",
    watermark: "text-[#b08a6b]/15",
  },
};
const t = themes[variant] ?? themes.rose;

const icons = {
  projet: '<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="m9 14 2 2 4-4"/>',
  logistique: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  marketing: '<path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>',
  flexibilite: '<path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/>',
  equipe: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  apprentissage: '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
};
const iconPath = icons[skill.icon] ?? icons.projet;
---

<article class={`relative flex flex-col items-center overflow-hidden rounded-3xl px-6 py-8 text-center shadow-lg ring-1 ${t.card}`}>
  <span
    aria-hidden="true"
    class={`pointer-events-none absolute -bottom-5 -right-2 select-none font-display font-black leading-none text-[5.5rem] ${t.watermark}`}
  >
    {filled}
  </span>

  <span class={`relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl ${t.iconWrap}`}>
    <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPath}></svg>
  </span>

  <h3 class={`relative z-10 mt-4 font-display text-xl font-extrabold uppercase leading-tight tracking-tight break-words [hyphens:auto] sm:text-2xl lg:text-3xl ${t.title}`} lang="fr">
    {skill.title}
  </h3>

  <div class="relative z-10 mt-3 flex flex-col items-center gap-2">
    <span class={`rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide ${t.pill}`}>{skill.niveau}</span>
    <div class="flex gap-1.5" aria-hidden="true">
      {tiers.map((_, i) => (
        <span class={`h-1.5 w-6 rounded-full ${i < filled ? t.seg : t.segOff}`}></span>
      ))}
    </div>
  </div>

  <ul class={`relative z-10 mx-auto mt-5 max-w-xs space-y-2 text-left ${t.text}`}>
    {skill.items.map((item) => (
      <li class="flex items-start gap-2.5">
        <span class={`mt-2 h-1.5 w-1.5 shrink-0 rounded-full ${t.dot}`} aria-hidden="true"></span>
        <span class="font-medium leading-snug">{item}</span>
      </li>
    ))}
  </ul>
</article>
