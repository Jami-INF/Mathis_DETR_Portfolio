---
// src/components/section/competence/CompetenceBloc.astro
import ScoreBadge from "./ScoreBadge.astro";
import LevelBar from "./LevelBar.astro";
import RadialGauge from "./RadialGauge.astro";

const { bloc, index = 0 } = Astro.props;
const idx = String(index + 1).padStart(2, "0");
const moyenne = Number(String(bloc.moyenne).replace(",", "."));
---

<article class="overflow-hidden rounded-3xl bg-white ring-1 ring-[#f1ddef] shadow-lg shadow-[#e7a7f4]/30">
  <header class="relative flex items-center justify-between gap-4 overflow-hidden bg-gradient-to-r from-[#e9a7e4] to-[#c98be0] px-6 py-5">
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -left-3 -top-7 select-none font-display font-black leading-none text-[7rem] text-white/15"
    >
      {idx}
    </span>
    <div class="relative z-10 min-w-0">
      <h3 class="font-display text-2xl font-extrabold uppercase tracking-wide text-white sm:text-3xl">
        {bloc.title}
      </h3>
      <p class="text-sm text-white/85">{bloc.sousTitre}</p>
    </div>
    <RadialGauge
      value={moyenne}
      max={5}
      size={92}
      stroke={9}
      label={bloc.moyenne}
      unit="/5"
      labelClass="text-xl"
      from="#ffffff"
      to="#ffffff"
      track="rgba(255,255,255,0.32)"
      textColor="#ffffff"
    />
  </header>

  <ul class="divide-y divide-[#f5e7f3]">
    {bloc.competences.map((c) => (
      <li class="grid gap-3 px-6 py-4 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-6">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span class="font-semibold text-[#4a3528]">{c.nom}</span>
            <ScoreBadge score={c.score} />
          </div>
          <p class="mt-1 text-sm text-[#9b8794]">{c.exemple}</p>
        </div>
        <LevelBar niveau={c.niveau} />
      </li>
    ))}
  </ul>
</article>
