---
import ProjetCard from './../../item/ProjetCard.astro';
import GalerieSection from './../GalerieSection.astro';
import BigTitle from "./../../text/BigTitle.astro";
import Title from "./../../text/Title.astro";
import type { ImageMetadata } from 'astro';

export interface Projet {
  title: string;
  title2: string;
  description: string;
  /** Rôle occupé (ex: "Co-fondateur & chargé de projet"). */
  role?: string;
  missions?: string[];
  /** Résultats / réalisations concrètes. */
  results?: string[];
  /** Image de couverture importée (optionnelle : placeholder si absente). */
  image?: ImageMetadata;
  imageAlt?: string;
  /**
   * Dossier de galerie associé (ex: "Hall 32", "MJ Prod").
   * Si absent, on le déduit du titre. La galerie ne s'affiche que s'il
   * existe des images dans /src/assets/galerie/<dossier>/.
   */
  galerie?: string;
}

interface Props {
  projets?: Projet[];
  /** Titre principal de la section (ex: "Mes projets", "Mes événements"). */
  title?: string;
  /** id de la <section> (pour l'ancrage). */
  sectionId?: string;
}

const {
  projets = [],
  title = 'Mes projets',
  sectionId = 'projets',
} = Astro.props;

// "Hall 32" -> "hall-32"
const slugify = (value: string) =>
  value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
---

<section id={sectionId} class="bg-[#f8f6f2]">

  <div class="max-w-7xl mx-auto px-6 pt-16">
    <BigTitle
      line1={title}
      line2=""
      sizeClass="text-[2.5rem] sm:text-[3.5rem] lg:text-[4.5rem]"
    />

  {
    projets.map((projet, index) => {
      const folder = projet.galerie ?? slugify(projet.title);
      return (
        <Fragment>
          <div class="max-w-7xl mx-auto px-6 py-14">
            <ProjetCard
              title={projet.title}
              title2={projet.title2}
              description={projet.description}
              role={projet.role}
              missions={projet.missions}
              results={projet.results}
              image={projet.image}
              imageAlt={projet.imageAlt}
              reverse={index % 2 === 1}
            />
          </div>


          {/* Ne s'affiche que si le dossier contient des images. */}
          <GalerieSection path={folder} eyebrow="Galerie" title={projet.title} description="" />
          <hr class="w-[90%] mx-auto border-0 h-1 bg-[#EED1F1] rounded-full" />

        </Fragment>
      );
    })
  }

  <div class="pb-16" />
</section>