---
import BigTitle from "./../text/BigTitle.astro";
import personalite from "./../../assets/element/protagonist.svg";
---

<section class="relative mx-auto w-full overflow-hidden bg-white py-12">
    <div class="absolute inset-0 bg-[#edd1f1] [clip-path:polygon(100%_80%,100%_0,0_100%)] z-0 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 lg:px-8">
    
    <div class="mb-10 text-center md:text-left">
      <BigTitle
        line1="PERSONALITÉ"
        line2="PROTAGONISTE"
        sizeClass="text-[2.5rem] sm:text-[3.5rem] lg:text-[4.5rem]"
      />
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      
      <div class="w-full md:w-8/12 flex justify-center">
        <img
          src={personalite.src || personalite}
          alt="Image de la personnalité Protagoniste"
          class="block w-full"
          loading="lazy"
        />
      </div>

      <div class="w-full md:w-4/12 space-y-6">
        
        <div class="bg-white/80 p-6 rounded-2xl shadow-sm backdrop-blur-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4 text-green-700">Points forts ✅</h3>
          <ul class="list-none space-y-2 text-lg text-gray-800">
            <li class="flex items-center gap-2"><span>•</span> Création de liens</li>
            <li class="flex items-center gap-2"><span>•</span> Organisé</li>
            <li class="flex items-center gap-2"><span>•</span> Résolution de problèmes</li>
            <li class="flex items-center gap-2"><span>•</span> Esprit d’équipe</li>
            <li class="flex items-center gap-2"><span>•</span> Communication efficace</li>
          </ul>
        </div>

        <div class="bg-white/80 p-6 rounded-2xl shadow-sm backdrop-blur-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4 text-red-700">Points faibles ❌</h3>
          <ul class="list-none space-y-2 text-lg text-gray-800">
            <li class="flex items-center gap-2"><span>•</span> Surinvestissement</li>
            <li class="flex items-center gap-2"><span>•</span> Sensible aux critiques</li>
            <li class="flex items-center gap-2"><span>•</span> Évitant les conflits nécessaires</li>
            <li class="flex items-center gap-2"><span>•</span> Prenant les choses trop à cœur</li>
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>