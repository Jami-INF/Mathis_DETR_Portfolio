---
const images = Object.entries(
  import.meta.glob('/src/assets/galerie/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}', {
    eager: true,
    import: 'default',
  })
).map(([path, image]) => {
  const fileName = path.split('/').pop() ?? '';
  const title = fileName.replace(/\.[^/.]+$/, '');

  return {
    src: image,
    title,
  };
});
---

<section id="galerie" class="py-2 bg-[#f8f6f2]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-[#e7a7f4] mb-3">
        Galerie
      </p>
      <h2 class="font-display text-4xl md:text-5xl uppercase tracking-tight text-[#6f5647] mb-4">
        Quelques images
      </h2>
      <p class="max-w-2xl text-base md:text-lg text-[#6f5647]/80 leading-relaxed">
        Une sélection d’images prises lors d'événements auxquels j'ai participé.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {images.map((image, index) => (
        <figure class="group overflow-hidden rounded-2xl bg-white/60 border border-black/10 shadow-sm">
          <img
            src={image.src.src}
            alt={image.title}
            loading="lazy"
            class="w-full h-80 object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />

          <figcaption class="px-5 py-4 text-sm font-bold uppercase tracking-[0.12em] text-[#6f5647] border-t border-black/5 bg-[#f8f6f2]/80">
            {image.title}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>