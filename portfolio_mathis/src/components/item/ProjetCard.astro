---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Title from "./../text/Title.astro";
import Text from "./../text/Text.astro";
import BigTitle from "./../text/BigTitle.astro";


interface Props {
  title: string;
  title2: string;
  description: string;
  /** Rôle occupé sur le projet (ex: "Co-fondateur & chargé de projet"). */
  role?: string;
  missions?: string[];
  /** Résultats / réalisations concrètes. */
  results?: string[];
  /** Image de couverture (optionnelle : placeholder si absente). */
  image?: ImageMetadata;
  imageAlt?: string;
  /** Inverse l'ordre texte / image (pour alterner d'un projet à l'autre). */
  reverse?: boolean;
}

const {
  title,
  title2,
  description,
  role,
  missions = [],
  results = [],
  image,
  imageAlt,
  reverse = false,
} = Astro.props;
---

<article class="grid items-start gap-8 lg:grid-cols-2 lg:gap-12">
  <!-- Colonne texte -->
  <div class={reverse ? 'lg:order-2' : ''}>
    <BigTitle line1={title} line2={title2} sizeClass="text-[1.5rem] sm:text-[3.5rem] lg:text-[3.5rem]"/>

    {role && (
      <p class="mt-2 inline-block rounded-full bg-[#e7a7f4]/20 px-4 py-1.5 text-sm font-bold uppercase tracking-[0.12em] text-[#6f5647]">
        {role}
      </p>
    )}

    <hr class="w-[90%] mx-auto border-0 h-1 bg-[#EED1F1] rounded-full my-4" />

    <Text text={description}/>

    {missions.length > 0 && (
      <>
      <hr class="w-[90%] mx-auto border-0 h-1 bg-[#EED1F1] rounded-full my-4" />
      <div class="rounded-2xl border border-[#6f5647]/15 bg-[#EED1F1]/20 p-6">
        <h4 class="text-xl font-extrabold tracking-tight text-[#6f5647] mb-3">
          Mes missions
        </h4>
        <ul class="space-y-2">
          {missions.map((mission) => (
            <li class="flex items-start gap-3 text-[#6f5647]">
              <span
                class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#6f5647]"
                aria-hidden="true"
              />
              <span class="font-medium leading-snug">{mission}</span>
            </li>
          ))}
        </ul>
      </div>
      </>
    )}

    {results.length > 0 && (
      <>
      <hr class="w-[90%] mx-auto border-0 h-1 bg-[#EED1F1] rounded-full my-4" />
      <div class="rounded-2xl border border-[#e7a7f4]/40 bg-white/60 p-6">
        <h4 class="text-xl font-extrabold tracking-tight text-[#6f5647] mb-3">
          Résultats
        </h4>
        <ul class="space-y-2">
          {results.map((result) => (
            <li class="flex items-start gap-3 text-[#6f5647]">
              <span
                class="mt-1 shrink-0 text-[#e7a7f4]"
                aria-hidden="true"
              >★</span>
              <span class="font-medium leading-snug">{result}</span>
            </li>
          ))}
        </ul>
      </div>
      </>
    )}
  </div>

  <!-- Colonne image -->
  <figure
    class={`overflow-hidden rounded-2xl border border-black/10 shadow-sm ${reverse ? 'lg:order-1' : ''}`}
  >
    {image ? (
      <Image
        src={image}
        alt={imageAlt ?? title}
        width={1200}
        quality={72}
        loading="lazy"
        class="w-full h-72 sm:h-96 lg:h-[28rem] object-cover"
      />
    ) : (
      <div class="flex h-72 sm:h-96 lg:h-[28rem] w-full items-center justify-center bg-gradient-to-br from-[#EED1F1] to-[#e7a7f4]/40">
        <span class="font-display text-3xl sm:text-5xl uppercase tracking-tight text-[#6f5647]/70">
          {title}
        </span>
      </div>
    )}
  </figure>
</article>